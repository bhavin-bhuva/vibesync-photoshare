generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlanTier {
  FREE
  PRO
  STUDIO
}

enum WatermarkPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
  BOTTOM_CENTER
}

enum SelectionStatus {
  PENDING
  REVIEWED
  DELIVERED
}

enum UserRole {
  PHOTOGRAPHER
  SUPER_ADMIN
}

enum SharedLinkAccessType {
  PASSWORD
  PIN
  NONE
}

enum PhotoStatus {
  UPLOADING
  READY
}

enum BillingInterval {
  MONTH
  YEAR
}

enum FaceJobStatus {
  PENDING
  RUNNING
  CLUSTERING
  DONE
  FAILED
}

enum FaceSearchStatus {
  PENDING
  SEARCHING
  DONE
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role             UserRole       @default(PHOTOGRAPHER)
  isSuspended      Boolean        @default(false)
  suspendedAt      DateTime?
  suspendedReason  String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  storageUsedBytes BigInt         @default(0)
  storageLimit     BigInt         @default(1073741824) // 1 GB
  events              Event[]
  subscription        Subscription?
  studioProfile       StudioProfile?
  adminActivityLogs   AdminActivityLog[]
}

model StudioProfile {
  id          String   @id @default(cuid())
  studioName  String
  logoS3Key   String?
  tagline     String?
  website     String?
  phone       String?
  address     String?
  brandColor         String?           // hex string e.g. "#3b82f6"
  watermarkEnabled   Boolean           @default(true)
  watermarkPosition  WatermarkPosition @default(BOTTOM_RIGHT)
  watermarkOpacity   Int               @default(55) // 10–80 (%)
  createdAt          DateTime          @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id                String      @id @default(cuid())
  name              String
  date              DateTime
  description       String?
  coverPhotoKey     String?
  hasNewSelections  Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos               Photo[]
  photoGroups          PhotoGroup[]
  sharedLinks          SharedLink[]
  faceIndexingEnabled  Boolean           @default(false)
  lastClusteredAt      DateTime?
  faceDataDeletedAt    DateTime?
  autoGroupByDate      Boolean           @default(false)
  faceRecords          FaceRecord[]
  faceClusters         FaceCluster[]
  faceIndexingJobs     FaceIndexingJob[]
}

model Photo {
  id              String          @id @default(cuid())
  s3Key           String
  thumbS3Key      String?
  filename        String
  size            Int
  status          PhotoStatus     @default(READY)
  width           Int?
  height          Int?
  createdAt       DateTime        @default(now())
  eventId         String
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  groupId         String?
  group           PhotoGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  selectedPhotos  SelectedPhoto[]
  faceRecords     FaceRecord[]

  @@index([groupId])
  @@index([eventId, groupId])
}

model PhotoGroup {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  color        String?  @default("#6366f1") // hex color for the filter pill UI
  coverPhotoId String?
  sortOrder    Int      @default(0)
  isVisible    Boolean  @default(true)
  photoCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]

  @@index([eventId])
  @@unique([eventId, name])
}

model SharedLink {
  id             String               @id @default(cuid())
  slug           String               @unique
  accessType     SharedLinkAccessType @default(PASSWORD)
  passwordHash   String?              // set when accessType = PASSWORD
  pin            String?              // bcrypt-hashed 4-digit PIN; set when accessType = PIN
  pinPlain       String?              // plain-text PIN stored for photographer recovery
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  eventId                  String
  event                    Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photoSelections          PhotoSelection[]
  faceSearchEnabled        Boolean              @default(false)
  groupVisibilityOverrides Json?                // map of groupId → boolean; null means use PhotoGroup.isVisible
}

model PhotoSelection {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  customerName   String
  customerEmail  String?
  customerNote   String?
  status         SelectionStatus @default(PENDING)
  sharedLinkId   String
  sharedLink     SharedLink      @relation(fields: [sharedLinkId], references: [id], onDelete: Cascade)
  selectedPhotos SelectedPhoto[]
}

model SelectedPhoto {
  id               String         @id @default(cuid())
  note             String?
  photoSelectionId String
  photoSelection   PhotoSelection @relation(fields: [photoSelectionId], references: [id], onDelete: Cascade)
  photoId          String
  photo            Photo          @relation(fields: [photoId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(cuid())
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  planTier             PlanTier  @default(FREE)
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model GalleryAccessAttempt {
  id          String   @id @default(cuid())
  slug        String
  ipAddress   String
  attemptedAt DateTime @default(now())

  @@index([slug, attemptedAt])
}

model StripePlan {
  id              String          @id @default(cuid())
  name            String          // e.g. "PRO", "STUDIO"
  displayName     String          // e.g. "Pro Plan", "Studio Plan"
  tier            PlanTier
  stripePriceId   String          @unique
  stripeProductId String?
  price           Decimal         @db.Decimal(10, 2)
  currency        String          @default("usd")
  interval        BillingInterval @default(MONTH)
  storageBytes    BigInt          // e.g. 107374182400 for 100 GB
  maxEvents       Int?            // null = unlimited
  features        Json            // string[] shown on pricing page
  isActive        Boolean         @default(true)
  isPopular       Boolean         @default(false)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model StripeWebhookConfig {
  id             String    @id @default(cuid())
  webhookSecret  String    // encrypted at rest
  endpointUrl    String
  isActive       Boolean   @default(true)
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WebhookLog {
  id            String   @id @default(cuid())
  eventType     String
  stripeEventId String
  status        String   // "SUCCESS" | "FAILED"
  errorMessage  String?
  processingMs  Int
  receivedAt    DateTime @default(now())

  @@index([receivedAt])
  @@index([stripeEventId, status])
}

model AdminActivityLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  action     String   // e.g. "SUSPENDED_USER", "DELETED_EVENT", "CHANGED_PLAN"
  targetType String   // e.g. "USER", "EVENT", "PHOTO"
  targetId   String
  metadata   Json?
  ipAddress  String?
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Restrict)
}

// ─── Face AI ──────────────────────────────────────────────────────────────────

model FaceRecord {
  id            String       @id @default(cuid())
  photoId       String
  photo         Photo        @relation(fields: [photoId], references: [id], onDelete: Cascade)
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faceClusterId String?
  faceCluster   FaceCluster? @relation(fields: [faceClusterId], references: [id])
  faceIndex     Int          // which face in the photo (0, 1, 2 …)
  confidence    Float        // detection confidence 0–1
  boundingBoxX1 Float
  boundingBoxY1 Float
  boundingBoxX2 Float
  boundingBoxY2 Float
  cropS3Key     String       // cropped face thumbnail in S3
  embedding     Bytes        // 512 × float32 stored as binary (~2 KB per face)
  createdAt     DateTime     @default(now())

  @@index([photoId])
  @@index([eventId])
  @@index([faceClusterId])
}

model FaceCluster {
  id             String       @id @default(cuid())
  eventId        String
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label          String?      // photographer sets: "Bride", "John", …
  coverCropS3Key String       // best face crop used as cluster thumbnail
  photoCount     Int          @default(0)
  faceCount      Int          @default(0)
  isHidden       Boolean      @default(false)
  faces          FaceRecord[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([eventId])
}

model FaceIndexingJob {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id])
  status          FaceJobStatus @default(PENDING)
  totalPhotos     Int           @default(0)
  processedPhotos Int           @default(0)
  facesFound      Int           @default(0)
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())

  @@index([eventId])
  @@index([status])
}

model FaceSearchSession {
  id                String           @id @default(cuid())
  slug              String           // same slug as SharedLink
  eventId           String
  selfieS3Key       String?
  matchedPhotoIds   Json             @default("[]")
  matchedClusterIds Json             @default("[]")
  status            FaceSearchStatus @default(PENDING)
  createdAt         DateTime         @default(now())
  expiresAt         DateTime         // 24 hours from creation

  @@index([slug])
}
